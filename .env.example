# ── 서버 환경변수 ──────────────────────────────────
# JWT 서명 시크릿 (production 필수)
JWT_SECRET=change-me-in-production

# Google OAuth (설정 안 하면 인증 없이 열림)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
ALLOWED_EMAIL=your@email.com

# Turso DB (설정 안 하면 로컬 SQLite 사용)
TURSO_DATABASE_URL=libsql://your-db.turso.io
TURSO_AUTH_TOKEN=your-turso-auth-token

# cli-worker 인증 시크릿 (서버↔worker 공유)
CLI_WORKER_SECRET=change-me-shared-secret

# 서버 포트 (기본 8888)
PORT=8888
